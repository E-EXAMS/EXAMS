{
  "name": "examshall",
  "version": "1.0.0",
  "description": "Full-Stack Bilingual Educational Assessment Portal",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon --exec node --loader ts-node/esm src/server/index.ts",
    "dev:client": "cd src/client && vite",
    "build": "npm run build:client && npm run build:server",
    "build:client": "cd src/client && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "preview": "npm run build && node dist/server.js",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "keywords": ["education", "assessment", "quiz", "mcq", "bilingual", "react", "typescript"],
  "author": "E-EXAMS Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "uuid": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0",
    "dotenv": "^16.0.3",
    "zod": "^3.22.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.3.8",
    "framer-motion": "^10.16.4",
    "lucide-react": "^0.263.1",
    "tailwindcss": "^3.3.2",
    "date-fns": "^2.30.0",
    "recharts": "^2.8.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "@types/react": "^18.2.14",
    "@types/react-dom": "^18.2.6",
    "@types/uuid": "^9.0.2",
    "@types/bcryptjs": "^2.4.2",
    "typescript": "^5.1.6",
    "ts-node": "^10.9.1",
    "vite": "^4.3.9",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.14",
    "postcss": "^8.4.24",
    "nodemon": "^2.0.22",
    "concurrently": "^8.1.0",
    "eslint": "^8.44.0",
    "@typescript-eslint/eslint-plugin": "^5.60.0",
    "@typescript-eslint/parser": "^5.60.0"
  }
}
